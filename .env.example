# Database Config
DB_HOST=db
DB_PORT=5432
DB_NAME=foodie_tour
DB_USER=postgres
DB_PASSWORD=password

# Application Config
PORT=8080
APPLICATION_NAME="Foodie Tour Backend"

# Mail Config (Required if app uses mail)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# AWS Config (Required for images)
REGION=ap-southeast-1
BUCKET=your_bucket_name
ACCESS_KEY=your_access_key
SECRET_KEY=your_secret_key

# Payment Config (If using payments)
VNP_TMN=your_tmn
VNP_HASH=your_hash
VNP_RETURN_URL=http://localhost:8080/api/payment/vnpay-return
VNP_IPN_URL=http://localhost:8080/api/payment/vnpay-ipn
VNP_EXPIRE_TIME=15

# Auth Config
AUTH_KEY=your_secure_random_key_64_chars_long
AUTH_ISSUER=foodie_tour
